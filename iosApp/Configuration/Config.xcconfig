// Optional include — build still works if Secrets.xcconfig is absent (vars resolve empty).
#include? "Secrets.xcconfig"

TEAM_ID=

PRODUCT_NAME=MoneyM
PRODUCT_BUNDLE_IDENTIFIER=com.dv.moneym.MoneyM$(TEAM_ID)
PRODUCT_BUNDLE_IDENTIFIER[config=Debug]=com.dv.moneym.MoneyM$(TEAM_ID).dev
INFOPLIST_KEY_CFBundleDisplayName=MoneyM
INFOPLIST_KEY_CFBundleDisplayName[config=Debug]=MoneyM Dev

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0